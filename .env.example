# PokeMarket — Environment Variables
# Copy this file to .env and fill in your values
# Run: cp .env.example .env

# ─── Firebase ────────────────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=your_api_key_here
EXPO_PUBLIC_FIREBASE_PROJECT_ID=pokemarket-255c6
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=pokemarket-255c6.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=129667382439
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# ─── Stripe ───────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=REPLACE_WITH_YOUR_KEY

# ─── Platform Fee Configuration ───────────────────────────────────────────
# Platform fee as decimal (0.03 = 3%)
EXPO_PUBLIC_PLATFORM_FEE_PERCENT=0.03

# Minimum total fee (Stripe + platform) in HKD
# All transactions pay at least this amount; below = floor applied
EXPO_PUBLIC_ORDER_MIN_FEE_HKD=20
