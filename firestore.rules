rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // HELPER FUNCTIONS
    // ─────────────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isOwner(userId) {
      return isAuthenticated() && uid() == userId;
    }

    // Admin check — add your uid to this list for emergency access
    function isAdmin() {
      return isAuthenticated() && uid() in [
        'REPLACE_WITH_YOUR_UID'
      ];
    }

    // ─────────────────────────────────────────────────────────────
    // CARD DATA — public read, Cloud Functions write only
    // card_prices: live market prices (20k+ cards)
    // cards: master card registry
    // ─────────────────────────────────────────────────────────────

    match /card_prices/{cardId} {
      allow read: if true;                           // Public — market data
      allow write: if isAdmin();                     // Only admin / Cloud Functions
    }

    match /cards/{cardId} {
      allow read: if true;                            // Public — card registry
      allow write: if isAdmin();                      // Only admin / Cloud Functions
    }

    // ─────────────────────────────────────────────────────────────
    // USERS
    // ─────────────────────────────────────────────────────────────

    match /users/{userId} {
      // Anyone authenticated can read other profiles (for chat/trade context)
      allow read: if isAuthenticated();
      // Only self can write their own profile
      allow write: if isOwner(userId);
    }

    // User's portfolio — only the owner can read/write their holdings
    match /users/{userId}/portfolio/{cardId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // User's card collection (for trade/my cards)
    match /users/{userId}/cards/{cardId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ─────────────────────────────────────────────────────────────
    // SELLERS — Stripe Connect accounts
    // ─────────────────────────────────────────────────────────────

    match /sellers/{sellerId} {
      // Read: own record OR any authenticated user (for trust checking)
      allow read: if isAuthenticated();
      // Write: own record OR Cloud Functions via service account
      allow write: if isOwner(sellerId);
    }

    // Seller notifications
    match /sellers/{sellerId}/notifications/{notifId} {
      allow read: if isOwner(sellerId);
      allow write: if isAdmin(); // Written by Cloud Functions
    }

    // ─────────────────────────────────────────────────────────────
    // ORDERS — Escrow payments
    // Critical: buyer/seller only, no one else
    // ─────────────────────────────────────────────────────────────

    match /orders/{orderId} {
      // Only buyer OR seller can read/write this order
      allow read: if isAuthenticated() && (
        resource.data.buyerId == uid() || resource.data.sellerId == uid()
      );
      // Create: authenticated users — Cloud Function validates all fields
      // Update: only buyer can confirm receipt (release funds)
      //        only buyer can raise dispute
      //        only system/Cloud Function can update status transitions
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.buyerId == uid() ||
        resource.data.sellerId == uid()
      );
      allow delete: if false; // Never delete orders — audit trail
    }

    // ─────────────────────────────────────────────────────────────
    // DISPUTES
    // ─────────────────────────────────────────────────────────────

    match /disputes/{disputeId} {
      allow read: if isAuthenticated() && (
        resource.data.buyerId == uid() || resource.data.sellerId == uid()
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.buyerId == uid() ||
        resource.data.sellerId == uid()
      );
      allow delete: if false;
    }

    // ─────────────────────────────────────────────────────────────
    // LISTINGS — Market listings
    // ─────────────────────────────────────────────────────────────

    match /listings/{listingId} {
      allow read: if true;                                    // Public — market browse
      // Only authenticated seller can create their own listing
      allow create: if isAuthenticated() && request.resource.data.sellerId == uid();
      // Only the seller of this listing can update/cancel it
      allow update: if isAuthenticated() && resource.data.sellerId == uid();
      allow delete: if isAuthenticated() && resource.data.sellerId == uid();
    }

    // ─────────────────────────────────────────────────────────────
    // OFFERS — Trade offers between users
    // ─────────────────────────────────────────────────────────────

    match /offers/{offerId} {
      // Buyer or seller can read their own offers
      allow read: if isAuthenticated() && (
        resource.data.buyerId == uid() || resource.data.sellerId == uid()
      );
      // Create: authenticated buyer
      allow create: if isAuthenticated() && request.resource.data.buyerId == uid();
      // Buyer or seller can update (accept/reject/counter)
      allow update: if isAuthenticated() && (
        resource.data.buyerId == uid() || resource.data.sellerId == uid()
      );
      allow delete: if isAuthenticated() && (
        resource.data.buyerId == uid() || resource.data.sellerId == uid()
      );
    }

    // ─────────────────────────────────────────────────────────────
    // TRADE HISTORY — Read only, written by Cloud Functions
    // ─────────────────────────────────────────────────────────────

    match /trade_history/{tradeId} {
      allow read: if isAuthenticated() && (
        resource.data.buyerId == uid() || resource.data.sellerId == uid()
      );
      allow write: if false; // Only Cloud Functions
    }

    // ─────────────────────────────────────────────────────────────
    // REVIEWS — Public read, authenticated write (own reviews only)
    // ─────────────────────────────────────────────────────────────

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == uid();
      allow update: if isAuthenticated() && resource.data.authorId == uid();
      allow delete: if isAuthenticated() && resource.data.authorId == uid();
    }

    // ─────────────────────────────────────────────────────────────
    // NOTIFICATIONS — Per-user only
    // ─────────────────────────────────────────────────────────────

    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.userId == uid();
      allow write: if false; // Only Cloud Functions
    }

    // ─────────────────────────────────────────────────────────────
    // CHAT — Thread-based messaging
    // ─────────────────────────────────────────────────────────────

    match /chat_threads/{threadId} {
      // Only participants can read/write the thread
      allow read: if isAuthenticated() && uid() in resource.data.participantIds;
      allow update: if isAuthenticated() && uid() in resource.data.participantIds;
    }

    match /chat_messages/{threadId}/messages/{messageId} {
      // Only thread participants can read messages
      allow read: if isAuthenticated();
      // Only participants can send messages (check via parent thread)
      allow create: if isAuthenticated();
      // Only message author can delete their own message
      allow delete: if isAuthenticated() && resource.data.senderId == uid();
    }

    // ─────────────────────────────────────────────────────────────
    // GLOBAL FALLBACK — Deny everything not explicitly matched
    // ─────────────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
